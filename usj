  .btn-cond:active{background:#3949ab}
  .btn-cond-play{display:inline-block;background:#00897b;color:#fff;border:none;border-radius:4px;padding:3px 6px;font-size:10px;cursor:pointer;white-space:nowrap}
  .btn-cond-play:active{background:#00695c}
  /* 待ち時間セル */
  .wait-cell{font-weight:bold;font-size:13px}
  .wt-green{color:#2e7d32}
  .wt-yellow{color:#e65100}
  .wt-red{color:#c62828;animation:pulse .8s infinite alternate}
  .wt-closed{color:#757575;font-size:10px;font-weight:normal}
  .wt-na{color:#999;font-size:10px;font-weight:normal}
  .wt-load{color:#aaa;font-size:10px}
  @keyframes pulse{from{opacity:1}to{opacity:.5}}
  .modal-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.55);z-index:100;justify-content:center;align-items:center;padding:20px}
  .modal-overlay.show{display:flex}
  .modal-box{background:#fff;border-radius:12px;padding:20px 16px;max-width:360px;width:100%;max-height:80vh;overflow-y:auto;position:relative}
  .modal-box h3{font-size:14px;margin-bottom:10px;padding-right:24px;color:#4a148c}
  .modal-box p{font-size:12px;margin-bottom:6px;line-height:1.6}
  .modal-box .tag{display:inline-block;background:#e8eaf6;border-radius:3px;padding:1px 6px;font-size:11px;margin-right:4px;margin-bottom:3px}
  .modal-close{position:absolute;top:10px;right:12px;background:none;border:none;font-size:22px;cursor:pointer;color:#666;line-height:1}
  .note{font-size:11px;color:#777;margin-top:6px;padding:0 8px}
  .note-warn{font-size:11px;color:#c62828;margin-top:6px;padding:0 8px;font-weight:bold}
</style>
