  .wl-yellow{background:#f57f17}
  .wl-red{background:#c62828}
  .wl-gray{background:#757575}
  .wait-bar button{background:#4a148c;color:#fff;border:none;border-radius:6px;padding:6px 14px;font-size:11px;font-weight:bold;cursor:pointer}
  .wait-bar button:active{background:#6a1b9a}
  .wait-status{width:100%;font-size:10px;color:#666}
  .section-title{font-size:14px;font-weight:bold;color:#4a148c;margin:18px 0 6px;padding:8px 12px;background:#ede7f6;border-radius:8px;border-left:4px solid #4a148c}
