<script>
// === モーダル制御 ===
function openModal(id){document.getElementById(id).classList.add('show');document.body.style.overflow='hidden'}
function closeModal(id){document.getElementById(id).classList.remove('show');document.body.style.overflow=''}
document.querySelectorAll('.modal-overlay').forEach(function(el){el.addEventListener('click',function(e){if(e.target===el){el.classList.remove('show');document.body.style.overflow=''}})});
document.addEventListener('keydown',function(e){if(e.key==='Escape'){document.querySelectorAll('.modal-overlay.show').forEach(function(el){el.classList.remove('show');document.body.style.overflow=''})}});

// === リアルタイム待ち時間 ===
// 正しいUSJ Park ID: 284
var API_URL = 'https://queue-times.com/parks/284/queue_times.json';

// API ride id → HTML element id（実データに基づく正確なマッピング）
var ID_MAP = {
  12061: 'w-mario-kart',       // Mario Kart: Koopa's Challenge
  12071: 'w-yoshi',            // Yoshi's Adventure
  14402: 'w-donkey',           // Mine Cart Madness (ドンキーコング)
  12065: 'w-forbidden',        // Harry Potter and the Forbidden Journey
  12073: 'w-hippogriff',       // Flight of the Hippogriff
  12197: 'w-ollivanders',      // Ollivanders
  14918: 'w-minion-mission',   // ミニオン・ハチャメチャ・ミッション
  12066: 'w-minion-ride',      // Despicable Me Minion Mayhem
  12072: 'w-freeze-ray',       // Freeze Ray Sliders (ハチャメチャ・アイス)
  14919: 'w-snoopy-ace',       // スヌーピーのフライング・エース・アドベンチャー
  12075: 'w-flying-snoopy',    // The Flying Snoopy
  7065:  'w-kitty-cup',        // Hello Kitty's Cupcake Dream
  7098:  'w-elmo-bubble',      // Elmo's Bubble Bubble
  7061:  'w-big-bird',         // Big Bird's Big Top Circus
  7067:  'w-elmo-skate',       // Elmo's Go-Go Skateboard
  7075:  'w-moppy',            // Moppy's Balloon Trip
  7071:  'w-elmo-drive',       // Elmo's Little Drive
  7092:  'w-flying-dino',      // The Flying Dinosaur
  12067: 'w-jurassic',         // Jurassic Park - The Ride
  12068: 'w-jaws',             // JAWS
  12082: 'w-space-fantasy',    // Space Fantasy - The Ride（通常版・休止中）
  15428: 'w-space-fantasy',    // スペース・ファンタジー～CLUB ZEDD REMIX～
  7077:  'w-hollywood',        // Hollywood Dream - The Ride
  12070: 'w-backdrop',         // Hollywood Dream - Backdrop
  7214:  'w-sing',             // SING ON TOUR
  12091: 'w-george',           // Playing with Curious George
  13005: 'w-conan',            // Detective Conan: The World
  7063:  'w-kitty-ribbon',     // Hello Kitty's Ribbon Collection
  15427: 'w-jujutsu'           // 呪術廻戦・ザ・リアル 4-D
};

function setWait(elId, mins, isOpen) {
  var el = document.getElementById(elId);
  if (!el) return;
  // クラスをリセット
  el.className = 'wait-cell';
  if (!isOpen) {
    el.textContent = '運休';
    el.classList.add('wt-closed');
  } else if (mins <= 30) {
    el.textContent = mins + '分';
    el.classList.add('wt-green');
  } else if (mins <= 60) {
    el.textContent = mins + '分';
    el.classList.add('wt-yellow');
  } else {
    el.textContent = mins + '分';
    el.classList.add('wt-red');
  }
}

function fetchWaitTimes() {
  fetch(API_URL)
    .then(function(res) {
      if (!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    })
    .then(function(data) {
      var matched = {};
      // rides配列を処理（USJ 284はlands空、rides直下）
      var allRides = data.rides || [];
      // lands配下にもある場合
      if (data.lands) {
        data.lands.forEach(function(land) {
          if (land.rides) allRides = allRides.concat(land.rides);
        });
      }
      allRides.forEach(function(ride) {
        var elId = ID_MAP[ride.id];
        if (elId && !matched[elId]) {
          setWait(elId, ride.wait_time, ride.is_open);
          matched[elId] = true;
        }
      });
      // マッチしなかったローディングセルを処理
      document.querySelectorAll('.wt-load').forEach(function(el) {
        if (!matched[el.id]) {
          el.textContent = '-';
          el.className = 'wait-cell wt-na';
        }
      });
      // 更新時刻
      var now = new Date();
      document.getElementById('lastUpdate').textContent =
        ('0'+now.getHours()).slice(-2) + ':' + ('0'+now.getMinutes()).slice(-2);
    })
    .catch(function(e) {
      console.error('待ち時間取得エラー:', e);
      document.getElementById('lastUpdate').textContent = '取得失敗';
      document.querySelectorAll('.wt-load').forEach(function(el) {
        el.textContent = '?';
        el.className = 'wait-cell wt-na';
      });
    });
}

// 初回取得
fetchWaitTimes();
// 5分毎に自動更新
setInterval(fetchWaitTimes, 5 * 60 * 1000);
</script>

