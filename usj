  thead th:first-child{text-align:left;padding-left:6px}
  /* 6列：アトラクション / 待ち / おすすめ / 5歳 / 3歳 / 条件 */
  th:nth-child(1),td:nth-child(1){width:34%}
  th:nth-child(2),td:nth-child(2){width:14%}
  th:nth-child(3),td:nth-child(3){width:13%}
  th:nth-child(4),td:nth-child(4){width:10%}
  th:nth-child(5),td:nth-child(5){width:10%}
  th:nth-child(6),td:nth-child(6){width:19%}
  /* プレイランド用（3列） */
  .play-table th:nth-child(1),.play-table td:nth-child(1){width:52%}
  .play-table th:nth-child(2),.play-table td:nth-child(2){width:22%}
  .play-table th:nth-child(3),.play-table td:nth-child(3){width:26%}
  tbody td{padding:6px 2px;font-size:11px;text-align:center;border-bottom:1px solid #eee;vertical-align:middle}
  tbody td:first-child{text-align:left;padding-left:6px;font-weight:600;font-size:10.5px;line-height:1.4}
  tr.ok4{background:#e8f5e9}
  tr.ok2{background:#fff8e1}
  tr.ng{background:#fce4ec}
  tr.show{background:#e3f2fd}
  tr.play{background:#e0f2f1}
  tr.closed{background:#f3e5f5}
  .mark-ok{color:#2e7d32;font-weight:bold;font-size:14px}
  .mark-cp{color:#f57f17;font-weight:bold;font-size:14px}
  .mark-ng{color:#c62828;font-weight:bold;font-size:14px}
  .mark-na{color:#999;font-size:12px}
